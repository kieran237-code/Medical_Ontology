<?xml version="1.0" encoding="UTF-8"?>

<!--
  Ontologie : Aliments et Santé (Diabète & Malnutrition) - Cameroun
  Auteur : INF 4188 - Semantic Web & Application
  Base URI : http://www.health-food.cm/2024/food-ontology#
-->

<rdf:RDF
  xmlns:rdf  ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs ="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl  ="http://www.w3.org/2002/07/owl#"
  xmlns:xsd  ="http://www.w3.org/2001/XMLSchema#"
  xmlns      ="http://www.health-food.cm/2024/food-ontology#"
  xml:base   ="http://www.health-food.cm/2024/food-ontology">

  <!-- ============================================================ -->
  <!--                  CLASSES PRINCIPALES                         -->
  <!-- ============================================================ -->

  <rdfs:Class rdf:ID="Food">
    <rdfs:label xml:lang="fr">aliment</rdfs:label>
    <rdfs:label xml:lang="en">Food</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Tout aliment consommé par une personne.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Person">
    <rdfs:label xml:lang="fr">personne</rdfs:label>
    <rdfs:comment xml:lang="fr">Un être humain consommant des aliments.</rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Patient">
    <rdfs:subClassOf rdf:resource="#Person"/>
    <rdfs:label xml:lang="fr">patient</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Une personne souffrant d'une maladie nutritionnelle.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Disease">
    <rdfs:label xml:lang="fr">maladie</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Une condition médicale pouvant être influencée par l'alimentation.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Diabetes">
    <rdfs:subClassOf rdf:resource="#Disease"/>
    <rdfs:label xml:lang="fr">diabète</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Maladie métabolique caractérisée par une hyperglycémie chronique.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Malnutrition">
    <rdfs:subClassOf rdf:resource="#Disease"/>
    <rdfs:label xml:lang="fr">malnutrition</rdfs:label>
    <rdfs:comment xml:lang="fr">
      État de déficience ou d'excès nutritionnel.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Obesity">
    <rdfs:subClassOf rdf:resource="#Disease"/>
    <rdfs:label xml:lang="fr">obésité</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Excès de masse grasse corporelle pouvant résulter d'une
      consommation excessive de certains aliments.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Nutrient">
    <rdfs:label xml:lang="fr">nutriment</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Substance contenue dans un aliment.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Region">
    <rdfs:label xml:lang="fr">région</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Zone géographique où un aliment est consommé.
    </rdfs:comment>
  </rdfs:Class>

  <!-- ============================================================ -->
  <!--             SOUS-CLASSES D'ALIMENTS LOCAUX                   -->
  <!-- ============================================================ -->

  <rdfs:Class rdf:ID="Eru">
    <rdfs:subClassOf rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">Eru</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Légume à feuilles consommé au Sud-Ouest et Littoral.
      Riche en fibres, bénéfique pour les diabétiques.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Koki">
    <rdfs:subClassOf rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">Koki</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Gâteau de haricots, typique de la région Ouest.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Sanga">
    <rdfs:subClassOf rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">Sanga</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Céréale consommée dans les régions Nord et Adamaoua.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Fufu">
    <rdfs:subClassOf rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">Fufu</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Pâte de manioc fermenté, aliment de base au Centre et Sud.
      Index glycémique élevé.
    </rdfs:comment>
  </rdfs:Class>

  <rdfs:Class rdf:ID="Okok">
    <rdfs:subClassOf rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">Okok</rdfs:label>
    <rdfs:comment xml:lang="fr">
      Plat à base de feuilles de gnetum et d'huile de palme,
      consommé au Centre et Sud. Riche en graisses si préparé
      avec beaucoup d'huile de palme.
    </rdfs:comment>
  </rdfs:Class>

  <!-- ============================================================ -->
  <!--                    PROPRIETES (RELATIONS)                     -->
  <!-- ============================================================ -->

  <rdf:Property rdf:ID="eats">
    <rdfs:domain rdf:resource="#Person"/>
    <rdfs:range  rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">mange</rdfs:label>
  </rdf:Property>

  <rdf:Property rdf:ID="contains">
    <rdfs:domain rdf:resource="#Food"/>
    <rdfs:range  rdf:resource="#Nutrient"/>
    <rdfs:label xml:lang="fr">contient</rdfs:label>
  </rdf:Property>

  <rdf:Property rdf:ID="isConsumedIn">
    <rdfs:domain rdf:resource="#Food"/>
    <rdfs:range  rdf:resource="#Region"/>
    <rdfs:label xml:lang="fr">est consommé dans</rdfs:label>
  </rdf:Property>

  <rdf:Property rdf:ID="preventsDisease">
    <rdfs:domain rdf:resource="#Food"/>
    <rdfs:range  rdf:resource="#Disease"/>
    <rdfs:label xml:lang="fr">prévient la maladie</rdfs:label>
  </rdf:Property>

  <rdf:Property rdf:ID="worsensDisease">
    <rdfs:domain rdf:resource="#Food"/>
    <rdfs:range  rdf:resource="#Disease"/>
    <rdfs:label xml:lang="fr">aggrave la maladie</rdfs:label>
  </rdf:Property>

  <rdf:Property rdf:ID="hasDiagnosis">
    <rdfs:domain rdf:resource="#Patient"/>
    <rdfs:range  rdf:resource="#Disease"/>
    <rdfs:label xml:lang="fr">a pour diagnostic</rdfs:label>
  </rdf:Property>

  <rdf:Property rdf:ID="glycemicIndex">
    <rdfs:domain rdf:resource="#Food"/>
    <rdfs:label xml:lang="fr">index glycémique</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Property>

  <!-- ============================================================ -->
  <!--          INSTANCES (DONNÉES CONCRÈTES À INTERROGER)          -->
  <!-- ============================================================ -->

  <!-- Régions -->
  <Region rdf:ID="Nord">
    <rdfs:label xml:lang="fr">Nord</rdfs:label>
  </Region>
  <Region rdf:ID="Ouest">
    <rdfs:label xml:lang="fr">Ouest</rdfs:label>
  </Region>
  <Region rdf:ID="Centre">
    <rdfs:label xml:lang="fr">Centre</rdfs:label>
  </Region>
  <Region rdf:ID="SudOuest">
    <rdfs:label xml:lang="fr">Sud-Ouest</rdfs:label>
  </Region>

  <!-- Instances d'aliments avec leurs relations -->
  <Eru rdf:ID="eru1">
    <rdfs:label xml:lang="fr">Eru</rdfs:label>
    <glycemicIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#float">25.0</glycemicIndex>
    <isConsumedIn rdf:resource="#SudOuest"/>
    <preventsDisease rdf:resource="#Diabetes"/>
  </Eru>

  <Koki rdf:ID="koki1">
    <rdfs:label xml:lang="fr">Koki</rdfs:label>
    <glycemicIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#float">40.0</glycemicIndex>
    <isConsumedIn rdf:resource="#Ouest"/>
    <preventsDisease rdf:resource="#Malnutrition"/>
  </Koki>

  <Sanga rdf:ID="sanga1">
    <rdfs:label xml:lang="fr">Sanga</rdfs:label>
    <glycemicIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#float">55.0</glycemicIndex>
    <isConsumedIn rdf:resource="#Nord"/>
    <preventsDisease rdf:resource="#Malnutrition"/>
  </Sanga>

  <Fufu rdf:ID="fufu1">
    <rdfs:label xml:lang="fr">Fufu</rdfs:label>
    <glycemicIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#float">85.0</glycemicIndex>
    <isConsumedIn rdf:resource="#Centre"/>
    <worsensDisease rdf:resource="#Diabetes"/>
  </Fufu>

  <Okok rdf:ID="okok1">
    <rdfs:label xml:lang="fr">Okok</rdfs:label>
    <glycemicIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#float">30.0</glycemicIndex>
    <isConsumedIn rdf:resource="#Centre"/>
    <worsensDisease rdf:resource="#Obesity"/>
  </Okok>

</rdf:RDF>